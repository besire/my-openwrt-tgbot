#!/bin/sh
# SPDX-License-Identifier: Apache-2.0
# shellcheck disable=SC2034,SC3043

LIB_DIR=${TGBOT_LIB_DIR:-/usr/libexec/tgbot/lib}
# shellcheck source=/dev/null
. "$LIB_DIR/common.sh"
# shellcheck source=/dev/null
. "$LIB_DIR/telegram.sh"
# shellcheck source=/dev/null
. "$LIB_DIR/status.sh"
# shellcheck source=/dev/null
. "$LIB_DIR/wol.sh"

TGBOT_RUNTIME_DIR=${TGBOT_RUNTIME_DIR:-/tmp/tgbot}
TGBOT_OFFSET_FILE=${TGBOT_OFFSET_FILE:-$TGBOT_RUNTIME_DIR/offset}
TGBOT_SLEEP_BIN=${TGBOT_SLEEP_BIN:-sleep}

tgbot_prepare_runtime() {
	umask 077
	mkdir -p "$TGBOT_RUNTIME_DIR" || return 1
	chmod 700 "$TGBOT_RUNTIME_DIR" 2>/dev/null || true
	wol_reset_confirmation_state
}

tgbot_read_offset() {
	local offset
	[ -r "$TGBOT_OFFSET_FILE" ] || return 1
	IFS= read -r offset <"$TGBOT_OFFSET_FILE" || return 1
	case "$offset" in ''|*[!0-9]*) return 1 ;; esac
	printf '%s\n' "$offset"
}

tgbot_write_offset() {
	local offset="$1" temporary="$TGBOT_OFFSET_FILE.$$"
	case "$offset" in ''|*[!0-9]*) return 1 ;; esac
	printf '%s\n' "$offset" >"$temporary" || return 1
	mv "$temporary" "$TGBOT_OFFSET_FILE"
}

tgbot_send_help() {
	telegram_send_text "$1" '可用命令：
/menu - 打开快捷菜单
/status - 查看路由器状态
/devices - 查看已配置设备状态
/network - 查看本地网络诊断
/wol - 选择并唤醒已配置设备
/help - 显示帮助'
}

_tgbot_add_menu_button() {
	json_add_object ''
	json_add_string text "$1"
	json_add_string callback_data "menu:$2"
	json_close_object
}

tgbot_send_menu() {
	local chat_id="$1" payload rc=0
	payload=$(telegram_new_payload_file) || return 1
	json_init
	json_add_string chat_id "$chat_id"
	json_add_string text '请选择操作：'
	json_add_object reply_markup
	json_add_array inline_keyboard
	json_add_array ''
	_tgbot_add_menu_button '路由器状态' status
	_tgbot_add_menu_button '设备状态' devices
	json_close_array
	json_add_array ''
	_tgbot_add_menu_button '网络诊断' network
	_tgbot_add_menu_button '唤醒设备' wol
	json_close_array
	json_close_array
	json_close_object
	json_dump >"$payload"
	telegram_submit_payload sendMessage "$payload" || rc=1
	rm -f "$payload"
	return "$rc"
}

tgbot_dispatch_action() {
	local action="$1" chat_id="$2"
	case "$action" in
		menu) tgbot_send_menu "$chat_id" ;;
		status)
			if tgbot_collect_status; then
				telegram_send_text "$chat_id" "$TGBOT_STATUS_TEXT"
			else
				telegram_send_text "$chat_id" '无法读取路由器状态。'
			fi
			;;
		devices) wol_send_device_status "$chat_id" ;;
		network)
			if tgbot_collect_network; then
				telegram_send_text "$chat_id" "$TGBOT_NETWORK_TEXT"
			else
				telegram_send_text "$chat_id" '无法读取网络状态。'
			fi
			;;
		wol) wol_send_target_keyboard "$chat_id" ;;
		*) return 1 ;;
	esac
}

tgbot_dispatch_message() {
	local command="${TGBOT_MESSAGE_TEXT%%[[:space:]]*}"
	case "$command" in
		/start|/menu) tgbot_dispatch_action menu "$TGBOT_CHAT_ID" ;;
		/help) tgbot_send_help "$TGBOT_CHAT_ID" ;;
		/status) tgbot_dispatch_action status "$TGBOT_CHAT_ID" ;;
		/devices) tgbot_dispatch_action devices "$TGBOT_CHAT_ID" ;;
		/network) tgbot_dispatch_action network "$TGBOT_CHAT_ID" ;;
		/wol) tgbot_dispatch_action wol "$TGBOT_CHAT_ID" ;;
		'') return 0 ;;
		*) telegram_send_text "$TGBOT_CHAT_ID" '未知命令，请使用 /help。' ;;
	esac
}

tgbot_dispatch_callback() {
	local callback_id="$1" data="$2" user_id="$3" chat_id="$4" action
	case "$data" in
		menu:status|menu:devices|menu:network|menu:wol)
			action=${data#menu:}
			telegram_answer_callback "$callback_id" '正在处理。' || true
			tgbot_dispatch_action "$action" "$chat_id"
			;;
		wol_select:*|wol_confirm:*|wol_cancel:*)
			wol_handle_callback "$callback_id" "$data" "$user_id" "$chat_id"
			;;
		*) telegram_answer_callback "$callback_id" '不支持或已失效的操作。' || true ;;
	esac
}

tgbot_dispatch_update() {
	if [ "$TGBOT_CHAT_TYPE" != private ] || ! tgbot_is_admin "$TGBOT_USER_ID"; then
		tgbot_log notice "ignored unauthorized update $TGBOT_UPDATE_ID"
		return 0
	fi
	case "$TGBOT_UPDATE_KIND" in
		message) tgbot_dispatch_message ;;
		callback) tgbot_dispatch_callback "$TGBOT_CALLBACK_ID" "$TGBOT_CALLBACK_DATA" "$TGBOT_USER_ID" "$TGBOT_CHAT_ID" ;;
	esac
}

tgbot_backoff_next() {
	local value="$1"
	value=$((value * 2))
	[ "$value" -le 60 ] || value=60
	printf '%s\n' "$value"
}

tgbot_main() {
	local offset response decode_rc next_offset backoff=1 discard_backlog=0 running=1

	tgbot_prepare_runtime || return 1
	tgbot_load_config || return 1
	if ! tgbot_validate_config strict; then
		tgbot_log err 'configuration validation failed'
		return 1
	fi

	if ! offset=$(tgbot_read_offset); then
		offset=-1
		discard_backlog=1
	fi
	trap 'running=0' INT TERM
	tgbot_log notice 'service started'

	while [ "$running" -eq 1 ]; do
		response=$(telegram_new_response_file) || return 1
		if ! telegram_poll "$offset" "$TGBOT_POLL_TIMEOUT" "$response"; then
			rm -f "$response"
			tgbot_log warning 'Telegram polling failed; retrying with backoff'
			"$TGBOT_SLEEP_BIN" "$backoff"
			backoff=$(tgbot_backoff_next "$backoff")
			continue
		fi
		backoff=1
		telegram_decode_update "$response"
		decode_rc=$?
		rm -f "$response"

		if [ "$decode_rc" -eq 2 ]; then
			if [ "$discard_backlog" -eq 1 ]; then
				offset=0
				tgbot_write_offset "$offset" || return 1
				discard_backlog=0
			fi
			continue
		fi
		[ "$decode_rc" -eq 0 ] || {
			tgbot_log warning 'ignored malformed Telegram update'
			continue
		}

		next_offset=$((TGBOT_UPDATE_ID + 1))
		tgbot_write_offset "$next_offset" || return 1
		offset=$next_offset
		if [ "$discard_backlog" -eq 1 ]; then
			discard_backlog=0
			continue
		fi
		tgbot_dispatch_update || tgbot_log warning "update $TGBOT_UPDATE_ID failed"
	done
	tgbot_log notice 'service stopped'
}

if [ "${TGBOT_SOURCE_ONLY:-0}" != 1 ]; then
	tgbot_main "$@"
fi
