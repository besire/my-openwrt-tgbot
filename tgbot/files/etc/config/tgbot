config bot 'main'
	option enabled '0'
	option token ''
	option api_base_url 'https://api.telegram.org'
	list status_interface 'wan'
	list status_interface 'wan6'
	option poll_timeout '50'
	option wake_check_delay '5'
	option wake_check_attempts '6'
	option wake_check_interval '5'

