#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: Apache-2.0
# shellcheck disable=SC2034,SC3043

START=90
STOP=10
USE_PROCD=1

PROG=/usr/libexec/tgbot/tgbotd
VALIDATE=/usr/libexec/tgbot/validate

start_service() {
	local enabled

	config_load tgbot
	config_get_bool enabled main enabled 0
	[ "$enabled" -eq 1 ] || return 0

	if ! "$VALIDATE" --strict >/dev/null; then
		logger -t tgbot -p daemon.err 'configuration validation failed; service not started'
		return 1
	fi

	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param limits core='0 0'
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger tgbot
}
