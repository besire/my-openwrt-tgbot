#!/bin/sh
# SPDX-License-Identifier: Apache-2.0

LIB_DIR=${TGBOT_LIB_DIR:-/usr/libexec/tgbot/lib}
# shellcheck source=/dev/null
. "$LIB_DIR/common.sh"

umask 077
TGBOT_RUNTIME_DIR=$(mktemp -d /tmp/tgbot-test-api.XXXXXX) || exit 1
export TGBOT_RUNTIME_DIR
trap 'rm -rf "$TGBOT_RUNTIME_DIR"' EXIT INT TERM

# shellcheck source=/dev/null
. "$LIB_DIR/telegram.sh"

tgbot_load_config || {
	printf '%s\n' 'Unable to load tgbot configuration.'
	exit 1
}
tgbot_is_token "$TGBOT_TOKEN" || {
	printf '%s\n' 'Bot token is missing or invalid.'
	exit 1
}
tgbot_is_https_url "$TGBOT_API_BASE_URL" || {
	printf '%s\n' 'Telegram API base URL is invalid.'
	exit 1
}

if telegram_test_api; then
	printf 'Telegram API connection succeeded%s.\n' "${TGBOT_BOT_USERNAME:+ (@$TGBOT_BOT_USERNAME)}"
	exit 0
fi
printf '%s\n' "Telegram API connection failed: $TGBOT_TELEGRAM_ERROR"
exit 1
